# ============================================
#  安全警告：请勿将真实 API Key 提交到 Git！
#  1. 复制此文件为 .env
#  2. 在 .env 中填入你的真实 API Key
#  3. .env 已在 .gitignore 中，不会被提交
#  4. 如果不小心已提交过真实 Key，请立即到对应平台轮换密钥
# ============================================

# ---- LLM 供应商 API Key（按 config.yaml 的 provider 字段选择）----

# DeepSeek（默认）
DEEPSEEK_API_KEY=sk-your-key-here

# OpenAI（将 config.yaml 中 provider 改为 openai）
# OPENAI_API_KEY=sk-your-key-here

# Anthropic Claude（将 config.yaml 中 provider 改为 anthropic）
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# Ollama 本地运行（将 config.yaml 中 provider 改为 ollama）
# 无需 API Key，但需确保 ollama serve 已启动

# ---- 腾讯云图像识别（可选）----
TENCENT_SECRET_ID=AKID-your-secret-id
TENCENT_SECRET_KEY=your-secret-key
TENCENT_REGION=ap-guangzhou
